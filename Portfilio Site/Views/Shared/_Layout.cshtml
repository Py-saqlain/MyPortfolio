<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - My Portfolio</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-dark text-light">
    <div class="tech-fall-container">
        <i class="fab fa-docker falling-icon" style="left: 10%; animation-duration: 12s;"></i>
        <i class="fab fa-microsoft falling-icon" style="left: 25%; animation-duration: 15s; animation-delay: 2s;"></i>
        <i class="fab fa-github falling-icon" style="left: 45%; animation-duration: 10s; animation-delay: 4s;"></i>
        <i class="fab fa-python falling-icon" style="left: 65%; animation-duration: 14s;"></i>
        <i class="fab fa-react falling-icon" style="left: 80%; animation-duration: 18s; animation-delay: 1s;"></i>
        <i class="fas fa-database falling-icon" style="left: 90%; animation-duration: 11s; animation-delay: 3s;"></i>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-info" href="#hero">Saqlain Rashid.</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#skills">Skills</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#projects">Projects</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                    @* Download resume *@
                    <li class="nav-item ms-md-3 mt-2 mt-md-0">
                        <button type="button" class="btn btn-outline-info rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#resumeModal">
                            <i class="bi bi-file-earmark-person me-2"></i> Resume
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="border-top border-secondary footer text-muted bg-dark mt-5 py-3 text-center">
        <div class="container">
            &copy; 2026 - MyPortfolio
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 1000, // Animation takes 1 second
            once: true      // Animation happens only once when scrolling down
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <div class="modal fade" id="resumeModal" tabindex="-1" aria-labelledby="resumeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-light border-info shadow-lg" style="border-width: 2px; border-radius: 15px;">

                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-info fw-bold" id="resumeModalLabel">
                        <i class="fas fa-file-pdf me-2"></i>Resume Options
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body text-center py-5">
                    <p class="text-secondary mb-4 fs-5">How would you like to access my resume?</p>

                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                        <a href="/My_Resume.pdf" target="_blank" class="btn btn-outline-info rounded-pill px-4 py-2 fw-bold w-100">
                            <i class="fas fa-eye me-2"></i> View in Browser
                        </a>

                        <a href="/My_Resume.pdf" download="Saqlain_Rashid_Resume.pdf" class="btn btn-info text-dark rounded-pill px-4 py-2 fw-bold w-100 shadow-sm">
                            <i class="fas fa-download me-2"></i> Download PDF
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>