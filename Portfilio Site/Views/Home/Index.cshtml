@model List<Portfilio_Site.Models.ProjectModel>

@{
    ViewData["Title"] = "Home";
}

<section id="hero" class="min-vh-100 d-flex align-items-center text-center bg-transparent">
    <div class="container position-relative" style="z-index: 1;" data-aos="zoom-in" data-aos-duration="1000">

        <p class="text-info font-monospace mb-3 fs-4" data-aos="fade-down" data-aos-delay="200">Hello, I'm</p>

        <h1 class="fw-bolder text-white mb-3" style="font-size: clamp(3.5rem, 8vw, 5.5rem); letter-spacing: -2px;">
            Saqlain <span class="text-info">Rashid</span>
        </h1>

        <h3 class="text-secondary mb-5 fw-light fs-4" data-aos="fade-up" data-aos-delay="400">
            Passionate <span class="text-info fw-bold">Software Engineer & AI Enthusiast</span>
        </h3>

        <div class="d-flex justify-content-center gap-3 mb-5 flex-wrap" data-aos="fade-up" data-aos-delay="600">
            <a href="#projects" class="btn btn-info rounded-pill text-dark fw-bold px-5 py-3 shadow-lg hover-scale">
                <i class="fas fa-briefcase me-2"></i> View My Work
            </a>
            <a href="#contact" class="btn btn-outline-secondary rounded-pill text-light px-5 py-3 fw-bold shadow-lg hover-scale border-2">
                <i class="fas fa-envelope me-2"></i> Contact Me
            </a>
        </div>

        <div class="d-flex align-items-center justify-content-center mb-4" data-aos="fade-up" data-aos-delay="800">
            <div class="bg-secondary" style="height: 1px; width: 50px; opacity: 0.5;"></div>
            <span class="text-secondary px-3 font-monospace small tracking-wide">CONNECT WITH ME</span>
            <div class="bg-secondary" style="height: 1px; width: 50px; opacity: 0.5;"></div>
        </div>

        <div class="d-flex justify-content-center gap-4" data-aos="fade-up" data-aos-delay="1000">
            <a href="https://github.com/Py-saqlain" target="_blank" title="GitHub Profile"
               class="btn btn-outline-info rounded-circle d-flex align-items-center justify-content-center hover-scale shadow-sm border-2"
               style="width: 65px; height: 65px; font-size: 1.8rem;">
                <i class="fab fa-github"></i>
            </a>

            <a href="https://www.linkedin.com/in/py-saqlain/" target="_blank" title="LinkedIn Profile"
               class="btn btn-outline-info rounded-circle d-flex align-items-center justify-content-center hover-scale shadow-sm border-2"
               style="width: 65px; height: 65px; font-size: 1.8rem;">
                <i class="fab fa-linkedin-in"></i>
            </a>
        </div>

    </div>
</section>

<section id="about" class="py-5 bg-dark text-light border-top border-secondary min-vh-100 d-flex align-items-center">
    <div class="container py-5" data-aos="fade-up">

        <div class="row mb-5">
            <div class="col-12 text-center">
                <h2 class="display-5 fw-bold text-white mb-3">About <span class="text-info">Me</span></h2>
                <div class="mx-auto bg-info" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
        </div>

        <div class="row gy-5 align-items-center">
            <div class="col-lg-7 pe-lg-5">
                <h3 class="h4 text-info mb-3">Software Engineer & AI Enthusiast</h3>

                <p class="lead" style="line-height: 1.8; font-size: 1.1rem;">
                    I am an undergraduate student (Batch 2027) at <strong>Punjab University College of Information Technology (PUCIT)</strong>. My journey in tech began with a deep curiosity about how things work behind the scenes, which quickly evolved into a passion for building robust, scalable systems.
                </p>

                <p style="line-height: 1.8; color: #adb5bd;">
                    Today, my expertise lies at the intersection of modern backend architecture and intelligent data systems. I specialize in developing high-performance APIs using <strong>.NET Core (C#)</strong>, automating deployments with <strong>Docker & GitHub Actions</strong>, and integrating <strong>Machine Learning & Generative AI</strong> to create forward-thinking solutions.
                </p>

                <p style="line-height: 1.8; color: #adb5bd;">
                    When I am not containerizing microservices or fine-tuning models, I am constantly exploring new ways to write clean, efficient code that solves real-world problems.
                </p>
            </div>

            <div class="col-lg-5">
                <div class="card bg-transparent border-info shadow-lg h-100 rounded-4" style="border-width: 2px;">
                    <div class="card-body p-4 p-md-5">
                        <h4 class="card-title text-white mb-4 fw-bold">
                            <i class="fas fa-terminal text-info me-2"></i> Quick Profile
                        </h4>

                        <ul class="list-unstyled mb-0" style="font-size: 1.05rem;">
                            <li class="mb-3 border-bottom border-secondary pb-3 d-flex justify-content-between">
                                <span class="text-info fw-bold"><i class="fas fa-graduation-cap me-2"></i> Education</span>
                                <span class="text-light text-end">PUCIT (2027)</span>
                            </li>
                            <li class="mb-3 border-bottom border-secondary pb-3 d-flex justify-content-between">
                                <span class="text-info fw-bold"><i class="fas fa-code me-2"></i> Backend</span>
                                <span class="text-light text-end">C#, ASP.NET Core</span>
                            </li>
                            <li class="mb-3 border-bottom border-secondary pb-3 d-flex justify-content-between">
                                <span class="text-info fw-bold"><i class="fas fa-server me-2"></i> DevOps</span>
                                <span class="text-light text-end">Docker, CI/CD</span>
                            </li>
                            <li class="mb-3 border-bottom border-secondary pb-3 d-flex justify-content-between">
                                <span class="text-info fw-bold"><i class="fas fa-brain me-2"></i> AI / ML</span>
                                <span class="text-light text-end">Gen AI, Python</span>
                            </li>
                            <li class="pt-2 d-flex justify-content-between">
                                <span class="text-info fw-bold"><i class="fas fa-map-marker-alt me-2"></i> Location</span>
                                <span class="text-light text-end">Lahore, Pakistan</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
@* skills *@

<section id="skills" class="py-5 bg-dark text-light border-top border-secondary min-vh-100 d-flex align-items-center">
    <div class="container py-5">

        <div class="row mb-5" data-aos="fade-up">
            <div class="col-12 text-center">
                <h2 class="display-5 fw-bold text-white mb-3">My <span class="text-info">Skills</span></h2>
                <div class="mx-auto bg-info" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
        </div>

        <div class="row text-center gy-4">

            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="0">
                <div class="card bg-transparent border-info h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">
                    <div class="card-body p-4">
                        <i class="fas fa-robot text-info mb-3" style="font-size: 2.5rem;"></i>
                        <h4 class="card-title text-white mb-3 fw-bold">Generative AI & LLMs</h4>
                        <p class="card-text text-secondary" style="line-height: 1.6;">LangChain, LangGraph, RAG, OpenAI API, Prompt Engineering, FAISS</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card bg-transparent border-info h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">
                    <div class="card-body p-4">
                        <i class="fas fa-network-wired text-info mb-3" style="font-size: 2.5rem;"></i>
                        <h4 class="card-title text-white mb-3 fw-bold">Deep Learning</h4>
                        <p class="card-text text-secondary" style="line-height: 1.6;">TensorFlow, CNNs, LSTMs, GRUs, scikit-learn, Time-Series</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card bg-transparent border-info h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">
                    <div class="card-body p-4">
                        <i class="fas fa-server text-info mb-3" style="font-size: 2.5rem;"></i>
                        <h4 class="card-title text-white mb-3 fw-bold">Backend & APIs</h4>
                        <p class="card-text text-secondary" style="line-height: 1.6;">.NET Core 8, C#, ASP.NET, FastAPI, RESTful APIs, SQL</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card bg-transparent border-info h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">
                    <div class="card-body p-4">
                        <i class="fas fa-code text-info mb-3" style="font-size: 2.5rem;"></i>
                        <h4 class="card-title text-white mb-3 fw-bold">Languages</h4>
                        <p class="card-text text-secondary" style="line-height: 1.6;">Python, C#, C++, C, JavaScript, SQL</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="400">
                <div class="card bg-transparent border-info h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">
                    <div class="card-body p-4">
                        <i class="fas fa-laptop-code text-info mb-3" style="font-size: 2.5rem;"></i>
                        <h4 class="card-title text-white mb-3 fw-bold">Frontend</h4>
                        <p class="card-text text-secondary" style="line-height: 1.6;">HTML5, CSS3, Bootstrap 5, JavaScript, Responsive Design</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="500">
                <div class="card bg-transparent border-info h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">
                    <div class="card-body p-4">
                        <i class="fas fa-box-open text-info mb-3" style="font-size: 2.5rem;"></i>
                        <h4 class="card-title text-white mb-3 fw-bold">DevOps & Tools</h4>
                        <p class="card-text text-secondary" style="line-height: 1.6;">Docker, GitHub Actions (CI/CD), Git, Streamlit, HuggingFace</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

 @* Projects *@
<section id="projects" class="py-5 bg-dark text-light border-top border-secondary min-vh-100 d-flex align-items-center">
    <div class="container py-5">

        <div class="row mb-5" data-aos="fade-up">
            <div class="col-12 text-center">
                <h2 class="display-5 fw-bold text-white mb-3">My <span class="text-info">Projects</span></h2>
                <div class="mx-auto bg-info" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
        </div>

        <div class="row gy-4">
            @foreach (var project in Model)
            {
                <div class="col-md-6 col-lg-4" data-aos="flip-up" data-aos-duration="1000">
                    <div class="card bg-transparent border-info h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">

                        <div class="card-body p-4 d-flex flex-column">
                            <h4 class="card-title text-white fw-bold mb-3">@project.Title</h4>

                            <div class="mb-3">
                                <span class="badge bg-dark text-info border border-info px-2 py-1 text-wrap lh-base" style="font-size: 0.85rem;">
                                    <i class="fas fa-layer-group me-1"></i> @project.TechStack
                                </span>
                            </div>

                            <p class="card-text text-secondary mt-2 flex-grow-1" style="line-height: 1.6;">@project.Description</p>
                        </div>

                        <div class="card-footer bg-transparent border-0 p-4 pt-0 mt-auto">
                            <a href="@project.GithubLink" target="_blank" class="btn btn-outline-info w-100 rounded-pill fw-bold shadow-sm">
                                <i class="fab fa-github fa-lg me-2"></i> View Code
                            </a>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
</section>


@* CONTACT *@
<section id="contact" class="py-5 bg-dark text-light border-top border-secondary min-vh-100 d-flex align-items-center">
    <div class="container py-5">

        <div class="row mb-5" data-aos="fade-up">
            <div class="col-12 text-center">
                <h2 class="display-5 fw-bold text-white mb-3">Get in <span class="text-info">Touch</span></h2>
                <div class="mx-auto bg-info" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
        </div>

        <div class="row justify-content-center gy-4 text-center">

            <div class="col-md-6 col-lg-5" data-aos="fade-up" data-aos-delay="0">
                <div class="card bg-transparent border-info h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">
                    <div class="card-body p-5 d-flex flex-column align-items-center">

                        <div class="bg-dark border border-info rounded-circle d-flex justify-content-center align-items-center mb-4 shadow" style="width: 80px; height: 80px;">
                            <i class="fas fa-envelope text-info" style="font-size: 2rem;"></i>
                        </div>

                        <h4 class="card-title text-white fw-bold mb-3">Email Me</h4>
                        <p class="card-text text-secondary mb-4 flex-grow-1" style="line-height: 1.6;">
                            Drop me an email and I will get back to you as soon as possible.
                        </p>

                        <a href="mailto:saqlainrashid661@gmail.com" class="btn btn-outline-info rounded-pill px-4 py-2 fw-bold w-100 shadow-sm">
                            <i class="fas fa-paper-plane me-2"></i> Send an Email
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-5" data-aos="fade-up" data-aos-delay="200">
                <div class="card bg-transparent border-success h-100 shadow-lg rounded-4 hover-scale" style="border-width: 2px; transition: transform 0.3s ease;">
                    <div class="card-body p-5 d-flex flex-column align-items-center">

                        <div class="bg-dark border border-success rounded-circle d-flex justify-content-center align-items-center mb-4 shadow" style="width: 80px; height: 80px;">
                            <i class="fab fa-whatsapp text-success" style="font-size: 2.2rem;"></i>
                        </div>

                        <h4 class="card-title text-white fw-bold mb-3">WhatsApp</h4>
                        <p class="card-text text-secondary mb-4 flex-grow-1" style="line-height: 1.6;">
                            Want a faster response? Let's chat directly on WhatsApp.
                        </p>

                        <a href="https://wa.me/923270337903?text=Hi!%20I%20saw%20your%20portfolio%20and%20would%20love%20to%20connect." target="_blank" class="btn btn-outline-success rounded-pill px-4 py-2 fw-bold w-100 shadow-sm">
                            <i class="fab fa-whatsapp me-2"></i> Message on WhatsApp
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

