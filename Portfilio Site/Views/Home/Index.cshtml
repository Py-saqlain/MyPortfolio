                    <div class="card-body">
                        <i class="bi bi-whatsapp text-success display-4 mb-3 d-block"></i>
                        <h4 class="card-title text-light">WhatsApp</h4>
                        <p class="card-text text-secondary mb-4">Want a faster response? Let's chat directly on WhatsApp.</p>

                        <a href="https://wa.me/923270337903?text=Hi!%20I%20saw%20your%20portfolio%20and%20would%20love%20to%20connect." target="_blank" class="btn btn-outline-success rounded-pill px-4 position-relative z-index-top">
                            Message on WhatsApp
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>