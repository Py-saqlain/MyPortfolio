<div class="modal fade" id="resumeModal" tabindex="-1" aria-labelledby="resumeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-light border-info shadow-lg" style="border-width: 2px; border-radius: 15px;">

            <div class="modal-header border-secondary">
                <h5 class="modal-title text-info fw-bold" id="resumeModalLabel">
                    <i class="fas fa-file-pdf me-2"></i>Resume Options
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body text-center py-5">
                <p class="text-secondary mb-4 fs-5">How would you like to access my resume?</p>

                <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                    <a href="~/Resume_Saqlain_Rashid.pdf" target="_blank" class="btn btn-outline-info rounded-pill px-4 py-2 fw-bold hover-scale w-100">
                        <i class="fas fa-eye me-2"></i> View in Browser
                    </a>

                    <a href="~/Resume_Saqlain_Rashid.pdf" download="Saqlain_Rashid_Resume.pdf" class="btn btn-info text-dark rounded-pill px-4 py-2 fw-bold hover-scale w-100 shadow-sm">
                        <i class="fas fa-download me-2"></i> Download PDF
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>