@model List<Portfilio_Site.Models.ProjectModel>

@{
    ViewData["Title"] = "Home";
}

<section id="hero" class="min-vh-100 d-flex flex-column justify-content-center text-center">
    <div class="container" data-aos="zoom-in" data-aos-duration="1000">

        <span class="badge text-bg-info rounded-pill px-3 py-2 mb-4 fs-6 bg-opacity-10 text-info border border-info">
            <i class="bi bi-mortarboard-fill me-2"></i>SE Undergrad at PUCIT
        </span>

        <h1 class="display-2 fw-bolder text-white mb-3">
            Hi, I'm <span class="text-info">Saqlain</span>.
        </h1>

        <h3 class="text-secondary mb-4">
            Software Engineer & AI Enthusiast
        </h3>

        <p class="lead text-light mx-auto mb-5" style="max-width: 700px; line-height: 1.8;">
            I am a 6th-semester undergrad at Punjab University College of Information Technology (PUCIT), graduating in <strong>2027</strong>.
            I found my true passion at the intersection of robust backend architecture using <strong>.NET</strong> and intelligent systems powered by <strong>Machine Learning</strong> and <strong>Generative AI</strong>.
            Welcome to my digital workspace.
        </p>

        <div class="d-flex justify-content-center gap-3">
            <a href="#projects" class="btn btn-info rounded-pill px-5 py-3 fw-bold shadow">
                View My Work
            </a>
            <a href="#contact" class="btn btn-outline-light rounded-pill px-5 py-3 fw-bold">
                Let's Talk
            </a>
        </div>

    </div>
</section>

<section id="skills" class="min-vh-100 d-flex flex-column justify-content-center py-5 animated-bg">

    <ul class="circles">
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
    </ul>

    <div class="container">






       <h2 class="text-info border-bottom border-secondary pb-2 mb-5" data-aos="fade-right">Skills</h2>

        <div class="row text-center">

            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="0">
                <div class="card text-bg-dark border-info h-100 shadow skill-card">
                    <div class="card-body">
                        <h4 class="card-title text-info mb-3">Generative AI & LLMs</h4>
                        <p class="card-text">LangChain, LangGraph, RAG, OpenAI API, Prompt Engineering, FAISS</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="150">
                <div class="card text-bg-dark border-info h-100 shadow skill-card">
                    <div class="card-body">
                        <h4 class="card-title text-info mb-3">Deep Learning</h4>
                        <p class="card-text">TensorFlow, CNNs, LSTMs, GRUs, scikit-learn, Time-Series Classification</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card text-bg-dark border-info h-100 shadow skill-card">
                    <div class="card-body">
                        <h4 class="card-title text-info mb-3">Languages</h4>
                        <p class="card-text">Python, C#, C++, C, JavaScript, SQL</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="0">
                <div class="card text-bg-dark border-info h-100 shadow skill-card">
                    <div class="card-body">
                        <h4 class="card-title text-info mb-3">Backend & APIs</h4>
                        <p class="card-text">.NET 8, C#, ASP.NET Core, FastAPI, REST APIs, Python</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="150">
                <div class="card text-bg-dark border-info h-100 shadow skill-card">
                    <div class="card-body">
                        <h4 class="card-title text-info mb-3">Frontend</h4>
                        <p class="card-text">HTML5, CSS3, Bootstrap 5, JavaScript</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card text-bg-dark border-info h-100 shadow skill-card">
                    <div class="card-body">
                        <h4 class="card-title text-info mb-3">Tools & Deployment</h4>
                        <p class="card-text">Streamlit, HuggingFace Spaces, Git/GitHub</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section id="projects" class="min-vh-100 d-flex flex-column justify-content-center py-5 animated-bg">

    <ul class="circles">
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
    </ul>

    <div class="container relative-z-index">
        <h2 class="text-info border-bottom border-secondary pb-2 mb-5" data-aos="fade-right">Projects</h2>

        <div class="row">
            @foreach (var project in Model)
            {
                <div class="col-md-4 mb-4" data-aos="flip-up" data-aos-duration="1000">
                    <div class="card text-bg-dark border-secondary h-100 shadow-lg skill-card">
                        <div class="card-body">
                            <h4 class="card-title text-info fw-bold">@project.Title</h4>
                            <h6 class="card-subtitle mb-3 text-light">@project.TechStack</h6>
                            <p class="card-text text-secondary mt-3">@project.Description</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3 mt-auto">
                            <a href="@project.GithubLink" target="_blank" class="btn btn-outline-info w-100 rounded-pill z-index-top position-relative">
                                <i class="bi bi-github me-2"></i> View Code
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>



@* CONTACT *@
<section id="contact" class="min-vh-100 d-flex flex-column justify-content-center py-5 animated-bg">

    <ul class="circles">
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
        <li></li>
    </ul>

    <div class="container relative-z-index">
        <h2 class="text-info border-bottom border-secondary pb-2 mb-5" data-aos="fade-right">Get In Touch</h2>

        <div class="row justify-content-center text-center">

            <div class="col-md-5 mb-4" data-aos="fade-up" data-aos-delay="0">
                <div class="card text-bg-dark border-info h-100 shadow-lg skill-card py-4">
                    <div class="card-body">
                        <i class="bi bi-envelope-at text-info display-4 mb-3 d-block"></i>
                        <h4 class="card-title text-light">Email Me</h4>
                        <p class="card-text text-secondary mb-4">Drop me an email and I'll get back to you as soon as possible.</p>

                        <a href="mailto:saqlainrashid661@gmail.com" class="btn btn-outline-info rounded-pill px-4 position-relative z-index-top">
                            Send an Email
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-5 mb-4" data-aos="fade-up" data-aos-delay="200">
